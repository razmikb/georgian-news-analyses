# Copy this file to `.env` and fill in real values. `.env` is git-ignored — never commit it.
# The pipeline reads these; the frontend uses only SUPABASE_URL + SUPABASE_ANON_KEY.

# Supabase → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=            # public, read-only (safe in the browser)
SUPABASE_SERVICE_ROLE_KEY=    # SECRET — full write access, pipeline only, never in the frontend

# Google AI Studio → API keys (Gemini free tier: embeddings + event titles)
GEMINI_API_KEY=
